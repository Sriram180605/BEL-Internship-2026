data/
*.csv
*.xlsx
*.xlsm
*.xlsb
*.xls
*.tsv

# Python
__pycache__/
*.pyc
.venv/
venv/
env/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
